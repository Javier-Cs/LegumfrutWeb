---
const {url, name} = Astro.props;

interface Props {
    url: string;
    name: string;
}
---

<a 
    id={url === '/' ? 'home' : url.replace('/', '')}
    href={url}
    data-astro-prefetch
    class="rounded-lg text-base font-medium text-neutral-600 ring-zinc-500 outline-hidden hover:text-neutral-500 focus-visible:ring-3 md:py-3 md:text-sm 2xl:text-base dark:text-neutral-400 dark:ring-zinc-200 dark:hover:text-neutral-500 dark:focus:outline-hidden"
>
    {name}
</a>

