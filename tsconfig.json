{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      //"@/*": ["src/*"],
      "@styles/*":["src/assets/styles/*"],
      "@data/*": ["src/data_files/*"],
      "@layout/*":["src/layouts/*"],
      "@components/*":["src/components/*"],
      "@en/*":["src/utils/engli/*"],
      "@es/*":["src/utils/esp/*"]
    }
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}
